{
  "name": "growcold",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "pnpm --filter @growcold/web dev",
    "dev:mobile": "pnpm --filter @growcold/mobile start",
    "build:web": "pnpm --filter @growcold/web build",
    "db:start": "pnpm --filter @growcold/supabase exec supabase start",
    "db:reset": "pnpm --filter @growcold/supabase exec supabase db reset",
    "db:types": "pnpm --filter @growcold/supabase exec supabase gen types typescript --local > packages/supabase/types.ts",
    "typecheck": "pnpm -r run typecheck"
  }
}
