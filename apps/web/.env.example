# Copy to apps/web/.env.local for local auth + API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Server-only (never expose to the browser). Required for signup + OTP APIs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OTP delivery: EMAIL (Resend) for MVP; WHATSAPP reserved for go-live.
OTP_PROVIDER=EMAIL

# Optional: transactional email via https://resend.com (omit in dev to log OTP server-side only).
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=GrowCold <onboarding@yourdomain.com>
